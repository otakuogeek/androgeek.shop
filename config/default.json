{
  "system": {
    "port": 3000,
    "host": "0.0.0.0",
    "extensions": [
      {
        "name": "androgeek-branding",
        "resolve": "extensions/androgeek-branding",
        "enabled": true,
        "priority": 1
      }
    ]
  },
  "themeConfig": {
    "copyRight": "© 2026 AndroGeek. All Rights Reserved."
  },
  "shop": {
    "name": "Androgeek",
    "currency": "EUR",
    "language": "es",
    "country": "ES",
    "timezone": "Europe/Madrid"
  },
  "catalog": {
    "product": {
      "image": {
        "thumbnail": {
          "width": 100,
          "height": 100
        },
        "listing": {
          "width": 300,
          "height": 300
        },
        "single": {
          "width": 500,
          "height": 500
        }
      }
    }
  }
}
